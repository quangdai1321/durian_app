# ── Sao chép file này thành .env và điền giá trị thật ──────────
# cp .env.example .env

# Database (SQL Server local)
DATABASE_URL=mssql+aioodbc://SERVER\INSTANCE/Durian?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# Database (PostgreSQL - dùng khi deploy VPS)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/durian_db

# JWT Secret — tạo random: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# OpenAI API Key — lấy tại https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# App settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MODEL_PATH=./models/best.pt
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
